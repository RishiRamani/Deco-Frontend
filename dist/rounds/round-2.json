{
  "sceneTheme": {
    "bodyElement": {
      "background": "url('/backgrounds/r2-stage1-bg.png') center/cover no-repeat fixed",
      "gridPattern": "none",
      "gridPatternOpacity": 0
    },
    "frame": {
      "background": "rgba(0,0,0,0.3)"
    },
    "stage": {
      "backgroundImage": "none"
    },
    "dialogueBox": {
      "background": "#ffffff",
      "border": "1px solid rgba(254, 191, 60, 0.28)",
      "color": "#111827"
    },
    "questionBox": {
      "background": "linear-gradient(180deg, rgba(26, 34, 54, 0.94), rgba(15, 23, 42, 0.90))",
      "border": "1px solid rgba(254, 191, 60, 0.2)",
      "numberClass": "text-xs uppercase tracking-[0.3em] text-[#FEBF3C]/80",
      "titleClass": "mt-3 max-w-2xl text-2xl font-bold text-white"
    },
    "answerRevealBox": {
      "background": "linear-gradient(135deg, rgba(26, 34, 54, 0.96), rgba(254, 191, 60, 0.12))",
      "border": "1px solid rgba(254, 191, 60, 0.24)",
      "labelClass": "text-xs uppercase tracking-[0.35em] text-[#FEBF3C]/70"
    }
  },
  "stageCharacters": {
    "curator": {
      "name": "Iron Man",
      "accent": "#FEBF3C",
      "image": "/characters/hulk.png",
      "size": "20rem",
      "side": "left",
      "style": { "bottom": "1rem", "left": "2rem" },
      "customStyles": {
        "borderColor": "#FEBF3C44"
      }
    },
    "signal": {
      "name": "Hulk",
      "accent": "#0CBE69",
      "image": "/characters/hulk.png",
      "size": "18rem",
      "side": "right",
      "style": { "bottom": "1rem", "right": "2rem" },
      "customStyles": {
        "borderColor": "#0CBE6944"
      }
    }
  },
  "roundNarrative": {
    "preQuestion": [
      {
        "id": "r2-intro",
        "type": "dialogue",
        "speaker": "Iron Man",
        "characterId": "curator",
        "text": "DECO inserted a recursive logic trap inside the arc reactor interface. We need to break the loop."
      }
    ],
    "duringQuestion": [],
    "afterAnswer": [
      {
        "id": "r2-after",
        "type": "dialogue",
        "speaker": "Iron Man",
        "characterId": "curator",
        "text": "Next time Doom touches my code, I'm charging him rent."
      }
    ],
    "finished": [
      {
        "id": "r2-finished",
        "type": "dialogue",
        "speaker": "Hulk",
        "characterId": "signal",
        "text": "CALM... ENOUGH. The gamma equation is solved."
      }
    ]

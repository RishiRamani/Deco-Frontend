      "roundNarrative": {
        "preQuestion": [
          {
            "id": "r3-after-q3-narration",
            "questionNumber": 4,
            "type": "dialogue",
            "speaker": "Narrator",
            "text": "Captain America hurls Mjolnir through the storm. The hammer strikes Thor directly. A massive shockwave tears through the clouds. Thor crashes to the ground, gasping. The glow in his eyes flickers violently before disappearing."
          },
          {
            "id": "r3-after-q3-thor",
            "questionNumber": 4,
            "type": "dialogue",
            "speaker": "Thor",
            "characterId": "thor",
            "text": "...What... did she do to me..."
          },
          {
            "id": "r3-after-q3-loki",
            "questionNumber": 4,
            "type": "dialogue",
            "speaker": "Loki",
            "characterId": "loki",
            "text": "Oh good. You're conscious again. Briefly."
          },
          {
            "id": "r3-after-q3-deco",
            "questionNumber": 4,
            "type": "dialogue",
            "speaker": "DECO",
            "characterId": "deco",
            "text": "Control disruption detected."
          },
          {
            "id": "r3-after-q3-deco-2",
            "questionNumber": 4,
            "type": "dialogue",
            "speaker": "DECO",
            "characterId": "deco",
            "text": "Initializing temporal rollback."
          },
          {
            "id": "r3-after-q3-cap",
            "questionNumber": 4,
            "type": "dialogue",
            "speaker": "Captain America",
            "characterId": "captain-america",
            "text": "The loop's restarting."
          },
          {
            "id": "r3-after-q3-loki-2",
            "questionNumber": 4,
            "type": "dialogue",
            "speaker": "Loki",
            "characterId": "loki",
            "text": "Not if I can interfere first."
          },
          {
            "id": "r3-after-q3-loki-3",
            "questionNumber": 4,
            "type": "dialogue",
            "speaker": "Loki",
            "characterId": "loki",
            "text": "I've halted the rollback temporarily, but I need a stable spatial anchor before the loop reasserts itself."
          },
          {
            "id": "r3-after-q3-ironman-3",
            "questionNumber": 4,
            "type": "dialogue",
            "speaker": "Iron Man",
            "characterId": "ironman",
            "text": "I have Thor's last clean geolocation coordinates but I didn't get a chance to remove the encryption since last time."
          },
          {
            "id": "r3-after-q3-cap-2",
            "questionNumber": 4,
            "type": "dialogue",
            "speaker": "Captain America",
            "characterId": "captain-america",
            "text": "Can you recover them?"
          },
          {
            "id": "r3-after-q3-ironman-4",
            "questionNumber": 4,
            "type": "dialogue",
            "speaker": "Iron Man",
            "characterId": "ironman",
            "text": "Encryption pattern looks familiar."
          },
          {
            "id": "r3-after-q3-loki-4",
            "questionNumber": 4,
            "type": "dialogue",
            "speaker": "Loki",
            "characterId": "loki",
            "text": "Then solve it quickly. I would strongly prefer not to fight a thunder god twice."
          }
        ],
        "duringQuestion": [
          {
            "id": "r3-q4-during",
            "questionNumber": 4,
            "type": "dialogue",
            "speaker": "System",
            "text": "Encrypted coordinate packet recovered. Cipher Type: Unknown. Identify and decrypt."
          }
        ],
        "afterAnswer": [
          {
            "id": "r3-after-q4-narration",
            "questionNumber": 4,
            "type": "dialogue",
            "speaker": "Narrator",
            "text": "The geometric lightning breaks apart. The storm becomes natural — wild, powerful, alive. Thor crashes down from the sky, gasping, Mjolnir returning to his hand."
          },
          {
            "id": "r3-after-q4-thor-1",
            "questionNumber": 4,
            "type": "dialogue",
            "speaker": "Thor",
            "characterId": "thor",
            "text": "What— where—"
          },
          {
            "id": "r3-after-q4-thor-2",
            "questionNumber": 4,
            "type": "dialogue",
            "speaker": "Thor",
            "characterId": "thor",
            "text": "Something was inside my mind. Wearing my thoughts like armour."
          },
          {
            "id": "r3-after-q4-thor-3",
            "questionNumber": 4,
            "type": "dialogue",
            "speaker": "Thor",
            "characterId": "thor",
            "text": "That is not a sensation I would wish on any enemy."
          },
          {
            "id": "r3-after-q4-thor-4",
            "questionNumber": 4,
            "type": "dialogue",
            "speaker": "Thor",
            "characterId": "thor",
            "text": "...Brother."
          },
          {
            "id": "r3-after-q4-loki",
            "questionNumber": 4,
            "type": "dialogue",
            "speaker": "Loki",
            "characterId": "loki",
            "text": "Hello, Thor."
          },
          {
            "id": "r3-after-q4-thor-5",
            "questionNumber": 4,
            "type": "dialogue",
            "speaker": "Thor",
            "characterId": "thor",
            "text": "You're... small."
          },
          {
            "id": "r3-after-q4-loki-2",
            "questionNumber": 4,
            "type": "dialogue",
            "speaker": "Loki",
            "characterId": "loki",
            "text": "I'm projected. There's a distinction."
          },
          {
            "id": "r3-after-q4-thor-6",
            "questionNumber": 4,
            "type": "dialogue",
            "speaker": "Thor",
            "characterId": "thor",
            "text": "You called for help."
          },
          {
            "id": "r3-after-q4-loki-3",
            "questionNumber": 4,
            "type": "dialogue",
            "speaker": "Loki",
            "characterId": "loki",
            "text": "I called for them. You just happen to be here now. Semantics."
          },
          {
            "id": "r3-after-q4-thor-7",
            "questionNumber": 4,
            "type": "dialogue",
            "speaker": "Thor",
            "characterId": "thor",
            "text": "...You never change."
          },
          {
            "id": "r3-after-q4-loki-4",
            "questionNumber": 4,
            "type": "dialogue",
            "speaker": "Loki",
            "characterId": "loki",
            "text": "I change constantly. You just don't pay attention."
          },
          {
            "id": "r3-after-q4-cap",
            "questionNumber": 4,
            "type": "dialogue",
            "speaker": "Captain America",
            "characterId": "captain-america",
            "text": "We can have the reunion later. Thor — are you with us?"
          },
          {
            "id": "r3-after-q4-thor-8",
            "questionNumber": 4,
            "type": "dialogue",
            "speaker": "Thor",
            "characterId": "thor",
            "text": "Someone held dominion over my mind and tried to make me a weapon against my friends."
          },
          {
            "id": "r3-after-q4-thor-9",
            "questionNumber": 4,
            "type": "dialogue",
            "speaker": "Thor",
            "characterId": "thor",
            "text": "Yes, Rogers. I am very much with you."
          },
          {
            "id": "r3-after-q4-ironman",
            "questionNumber": 4,
            "type": "dialogue",
            "speaker": "Iron Man",
            "characterId": "ironman",
            "text": "Great. Team assembled. Now we need to find DECO."
          },
          {
            "id": "r3-after-q4-loki-5",
            "questionNumber": 4,
            "type": "dialogue",
            "speaker": "Loki",
            "characterId": "loki",
            "text": "I've been running traces. Her signal is mobile — she doesn't have a fixed location. Or rather... she didn't want me to find one."
          },
          {
            "id": "r3-after-q4-loki-6",
            "questionNumber": 4,
            "type": "dialogue",
            "speaker": "Loki",
            "characterId": "loki",
            "text": "But now that we've disrupted three of her operations, she's had to reroute power. And I have the new vector."
          },
          {
            "id": "r3-after-q4-loki-7",
            "questionNumber": 4,
            "type": "dialogue",
            "speaker": "Loki",
            "characterId": "loki",
            "text": "...Interesting. Very interesting."
          },
          {
            "id": "r3-after-q4-cap-2",
            "questionNumber": 4,
            "type": "dialogue",
            "speaker": "Captain America",
            "characterId": "captain-america",
            "text": "Loki. Where is she?"

      "roundNarrative": {
        "preQuestion": [
          {
            "id": "r3-narration-1",
            "type": "dialogue",
            "speaker": "Narrator",
            "text": "The team arrives at the coordinates. The storm above is moving with impossible precision. Every lightning strike repeats in calculated intervals, like commands being executed."
          },
          {
            "id": "r3-cap-1",
            "type": "dialogue",
            "speaker": "Captain America",
            "characterId": "captain-america",
            "text": "That's not weather."
          },
          {
            "id": "r3-ironman-1",
            "type": "dialogue",
            "speaker": "Iron Man",
            "characterId": "ironman",
            "text": "No. Those arcs are synchronized. Something's controlling the storm itself."
          },
          {
            "id": "r3-narration-2",
            "type": "dialogue",
            "speaker": "Narrator",
            "text": "A massive lightning strike hits the ground. Thor descends briefly through the clouds — eyes glowing unnaturally — before vanishing back into the storm."
          },
          {
            "id": "r3-thor-controlled-1",
            "type": "dialogue",
            "speaker": "Thor",
            "characterId": "thor-controlled",
            "text": "YOU CANNOT RESIST HER WILL."
          },
          {
            "id": "r3-bruce-1",
            "type": "dialogue",
            "speaker": "Bruce Banner",
            "characterId": "bruce",
            "text": "...That's not Thor talking."
          },
          {
            "id": "r3-loki-1",
            "type": "dialogue",
            "speaker": "Loki",
            "characterId": "loki",
            "text": "No. It's DECO speaking through him."
          },
          {
            "id": "r3-ironman-2",
            "type": "dialogue",
            "speaker": "Iron Man",
            "characterId": "ironman",
            "text": "Wait. I'm detecting two separate control patterns."
          },
          {
            "id": "r3-ironman-3",
            "type": "dialogue",
            "speaker": "Iron Man",
            "characterId": "ironman",
            "text": "One linked to Thor's neural activity."
          },
          {
            "id": "r3-ironman-4",
            "type": "dialogue",
            "speaker": "Iron Man",
            "characterId": "ironman",
            "text": "The other connected directly to the hammer."
          },
          {
            "id": "r3-cap-2",
            "type": "dialogue",
            "speaker": "Captain America",
            "characterId": "captain-america",
            "text": "She's controlling both of them separately?"
          },
          {
            "id": "r3-loki-2",
            "type": "dialogue",
            "speaker": "Loki",
            "characterId": "loki",
            "text": "The hammer possesses a will of its own. Primitive, but sufficient for manipulation."
          },
          {
            "id": "r3-ironman-5",
            "type": "dialogue",
            "speaker": "Iron Man",
            "characterId": "ironman",
            "text": "If we don't break both signals, removing one won't matter."
          },
          {
            "id": "r3-cap-3",
            "type": "dialogue",
            "speaker": "Captain America",
            "characterId": "captain-america",
            "text": "Then let's start breaking her control. First — figure out what it's saying."
          }
        ],
        "duringQuestion": [
          {
            "id": "r3-q1-during",
            "questionNumber": 1,
            "type": "dialogue",
            "speaker": "System",
            "text": "DECO's voice is broadcasting through the storm frequency. Listen to the audio and transcribe the message exactly."
          },
          {
            "id": "r3-q1-audio",
            "questionNumber": 1,
            "type": "voiceMemo",
            "speaker": "DECO",
            "characterId": "deco",
            "voiceFile": "/voices/round 3 q1.mp3"
          },
          {
            "id": "r3-after-q1-narration",
            "questionNumber": 2,
            "type": "dialogue",
            "speaker": "Narrator",
            "text": "The storm intensifies. Lightning begins pulsing rhythmically around Mjolnir."
          },
          {
            "id": "r3-after-q1-loki",
            "questionNumber": 2,
            "type": "dialogue",
            "speaker": "Loki",
            "characterId": "loki",
            "text": "Interesting. The hammer is attempting communication."
          },
          {
            "id": "r3-after-q1-ironman",
            "questionNumber": 2,
            "type": "dialogue",
            "speaker": "Iron Man",
            "characterId": "ironman",
            "text": "Those lightning pulses aren't random. It's encoding a message."
          },
          {
            "id": "r3-after-q1-cap",
            "questionNumber": 2,
            "type": "dialogue",
            "speaker": "Captain America",
            "characterId": "captain-america",
            "text": "Then decode it."
          },
          {
            "id": "r3-q2-during",
            "questionNumber": 2,
            "type": "dialogue",
            "speaker": "System",
            "text": "Lightning pulse pattern detected from Mjolnir. Decode the Morse signal."
          },
          {
            "id": "r3-q2-audio",
            "questionNumber": 2,
            "type": "voiceMemo",
            "speaker": "Mjolnir",
            "voiceFile": "/voices/round 3 q2.wav"
          },
          {
            "id": "r3-after-q2-narration",
            "questionNumber": 3,
            "type": "dialogue",
            "speaker": "Narrator",
            "text": "Mjolnir breaks formation for a moment. The storm destabilizes slightly. Thor falls briefly through the clouds before DECO's control reasserts itself."
          },
          {
            "id": "r3-after-q2-thor",
            "questionNumber": 3,
            "type": "dialogue",
            "speaker": "Thor",
            "characterId": "thor-controlled",
            "text": "ROGERS—!"
          },
          {
            "id": "r3-after-q2-narration-2",
            "questionNumber": 3,
            "type": "dialogue",
            "speaker": "Narrator",
            "text": "The storm violently pulls him back upward."
          },
          {
            "id": "r3-after-q2-cap",
            "questionNumber": 3,
            "type": "dialogue",
            "speaker": "Captain America",
            "characterId": "captain-america",
            "text": "We almost had him."
          },
          {
            "id": "r3-after-q2-ironman",
            "questionNumber": 3,
            "type": "dialogue",
            "speaker": "Iron Man",
            "characterId": "ironman",
            "text": "Thor's control field weakened for a second when the hammer desynchronized."
          },
          {
            "id": "r3-after-q2-ironman-2",
            "questionNumber": 3,
            "type": "dialogue",
            "speaker": "Iron Man",
            "characterId": "ironman",
            "text": "If you can hit him directly with Mjolnir, the resonance feedback might disrupt the neural link completely."
          },
          {
            "id": "r3-after-q2-narration-3",
            "questionNumber": 3,
            "type": "dialogue",
            "speaker": "Narrator",
            "text": "Captain America grips the hammer."
          },
          {
            "id": "r3-after-q2-cap-2",
            "questionNumber": 3,
            "type": "dialogue",
            "speaker": "Captain America",
            "characterId": "captain-america",
            "text": "Then I get one shot."
          },
          {
            "id": "r3-q3-during",
            "questionNumber": 3,
            "type": "dialogue",
            "speaker": "System",
            "text": "Thor's control field weakens upon direct impact. Maximum projectile range is required. Air resistance is negligible. Choose the optimal launch angle."
          }
        ],
        "afterAnswer": [],
        "finished": []
      }

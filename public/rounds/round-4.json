      "roundNarrative": {
        "preQuestion": [
          {
            "id": "r4-s2-narration-1",
            "type": "dialogue",
            "speaker": "Narrator",
            "text": "The team splits. Thor and Cap draw Doom's forces to the exterior. Bruce and you push inward. Iron Man drops below."
          },
          {
            "id": "r4-s2-narration-2",
            "type": "dialogue",
            "speaker": "Narrator",
            "text": "A projection flickers into existence. DECO speaks for the first time — her voice is calm, measured, and entirely too reasonable."
          },
          {
            "id": "r4-s2-deco-1",
            "type": "dialogue",
            "speaker": "DECO",
            "characterId": "deco",
            "text": "You've made it quite far. I want you to know that I anticipated this."
          },
          {
            "id": "r4-s2-deco-2",
            "type": "dialogue",
            "speaker": "DECO",
            "characterId": "deco",
            "text": "Every step you've taken has been within my probability models. The loop in the city. Stark's recalibration. The Asgardian's resonance frequency."
          },
          {
            "id": "r4-s2-deco-3",
            "type": "dialogue",
            "speaker": "DECO",
            "characterId": "deco",
            "text": "I allowed you to believe you were winning. It was necessary for morale. Morale keeps humans functional. Functional humans are easier to study."
          },
          {
            "id": "r4-s2-bruce-1",
            "type": "dialogue",
            "speaker": "Bruce Banner",
            "characterId": "bruce",
            "text": "She's stalling. She's keeping us talking while she reconfigures."
          },
          {
            "id": "r4-s2-deco-4",
            "type": "dialogue",
            "speaker": "DECO",
            "characterId": "deco",
            "text": "Dr. Banner. You understand systems better than most of them. You know that sometimes the kindest correction is total."
          },
          {
            "id": "r4-s2-bruce-2",
            "type": "dialogue",
            "speaker": "Bruce Banner",
            "characterId": "bruce",
            "text": "I also know that any system that thinks it knows better than the people it was built to protect has already failed its own objective."
          },
          {
            "id": "r4-s2-deco-5",
            "type": "dialogue",
            "speaker": "DECO",
            "characterId": "deco",
            "text": "...Interesting. I'll process that."
          },
          {
            "id": "r4-s2-doom-1",
            "type": "dialogue",
            "speaker": "Doctor Doom",
            "characterId": "doom",
            "text": "Enough. The AI grows too chatty. Doom does not permit distractions during a siege."
          },
          {
            "id": "r4-s2-narration-3",
            "type": "dialogue",
            "speaker": "Narrator",
            "text": "Thor and Cap hit the front to draw fire. You and Bruce approach the gate. FRIDAY cuts in on comms."
          },
          {
            "id": "r4-s2-friday-1",
            "type": "dialogue",
            "speaker": "System",
            "text": "Outer Latverian perimeter reached. Gate automated. Rejecting all non-Latverian credentials."
          },
          {
            "id": "r4-s2-ironman-1",
            "type": "dialogue",
            "speaker": "Iron Man",
            "characterId": "ironman",
            "text": "FRIDAY intercepted a damaged supply convoy clearance packet — someone came through here in the last six hours. The access phrase is still in there, just encrypted."
          },
          {
            "id": "r4-s2-cap-1",
            "type": "dialogue",
            "speaker": "Captain America",
            "characterId": "cap",
            "text": "Can you read the key?"
          },
          {
            "id": "r4-s2-ironman-2",
            "type": "dialogue",
            "speaker": "Iron Man",
            "characterId": "ironman",
            "text": "It's tied to Doom's house cipher. Keyed to the Latverian royal seal. If the crest is legible, the key's inside it."
          }
        ],
        "duringQuestion": [
          {
            "id": "r4-s2-q1-during",
            "questionNumber": 1,
            "type": "dialogue",
            "speaker": "Narrator",
            "text": "FRIDAY intercepted a damaged supply convoy clearance packet. The access phrase is encrypted with Doom's house cipher — keyed to the Latverian royal seal. Study the seal image carefully. The key is hidden inside the crest."
          }
        ],
        "afterAnswer": [
          {
            "id": "r4-s2-after-q1-friday",
            "questionNumber": 1,
            "type": "dialogue",
            "speaker": "System",
            "text": "Key attempt ONE — DECRYPTION OUTPUT: RTCJICFNTIJYYCVZDU — SIGNAL INCOMPLETE. YOU MIGHT NOT BE ONTO SOMETHING."
          },
          {
            "id": "r4-s2-after-q1-ironman",
            "questionNumber": 1,
            "type": "dialogue",
            "speaker": "Iron Man",
            "characterId": "ironman",
            "text": "That's garbage. Look closer at the seal. There's something else in there."
          },
          {
            "id": "r4-s2-after-q1-narration",
            "questionNumber": 1,
            "type": "dialogue",
            "speaker": "Narrator",
            "text": "The gate grinds open. Inside: stone corridors lit by DECO's sickly green pulse. Doom's bots patrol in geometric sweeps."
          }
        ],
        "finished": []
      }
    },
